{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "language": { "type": "string", "enum": ["pt", "en", "es"] },
        "isDarkMode": { "type": "boolean" },
        "primaryColor": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "subscription": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["free", "monthly"] },
            "expiryDate": { "type": "string", "format": "date-time" }
          }
        },
        "usage": {
          "type": "object",
          "properties": {
            "lastInvoiceDate": { "type": "string", "format": "date" },
            "dailyInvoiceCount": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email", "language"]
    },
    "Job": {
      "title": "Job",
      "description": "A work project or employer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "hourlyRate", "currency"]
    },
    "WorkSession": {
      "title": "Work Session",
      "description": "A single shift or work period",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "jobId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "breakMinutes": { "type": "number" },
        "isBreakPaid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "jobId", "date", "startTime", "endTime", "breakMinutes", "isBreakPaid"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "primaryColor": { "type": "string" }
      },
      "required": ["appName", "primaryColor"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A custom invoice created by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "orderNumber": { "type": "string" },
        "date": { "type": "string" },
        "dueDate": { "type": "string" },
        "issuer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "taxId": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "receiver": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "taxId": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "styles": { "type": "object" },
        "labels": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "invoiceNumber", "date", "total"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "User's jobs"
    },
    "/sessions/{sessionId}": {
      "schema": "WorkSession",
      "description": "Work sessions for jobs"
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global app settings"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "User's custom invoices"
    },
    "/shared_invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Publicly shared invoices"
    }
  }
}
